{
    "info": {
        "name": "Traffic Light Controller API",
        "_postman_id": "traffic-light-controller-collection",
        "description": "Postman collection for testing Traffic Light Controller API",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "Create Intersection",
            "request": {
                "method": "POST",
                "url": {
                    "raw": "http://localhost:8080/traffic/create/int1",
                    "protocol": "http",
                    "host": [
                        "localhost"
                    ],
                    "port": "8080",
                    "path": [
                        "traffic",
                        "create",
                        "int1"
                    ]
                }
            }
        },
        {
            "name": "Change Light - NORTH_SOUTH GREEN",
            "request": {
                "method": "POST",
                "url": {
                    "raw": "http://localhost:8080/traffic/int1/change?direction=NORTH_SOUTH&color=GREEN",
                    "protocol": "http",
                    "host": [
                        "localhost"
                    ],
                    "port": "8080",
                    "path": [
                        "traffic",
                        "int1",
                        "change"
                    ],
                    "query": [
                        {
                            "key": "direction",
                            "value": "NORTH_SOUTH"
                        },
                        {
                            "key": "color",
                            "value": "GREEN"
                        }
                    ]
                }
            }
        },
        {
            "name": "Pause Intersection",
            "request": {
                "method": "POST",
                "url": {
                    "raw": "http://localhost:8080/traffic/int1/pause",
                    "protocol": "http",
                    "host": [
                        "localhost"
                    ],
                    "port": "8080",
                    "path": [
                        "traffic",
                        "int1",
                        "pause"
                    ]
                }
            }
        },
        {
            "name": "Resume Intersection",
            "request": {
                "method": "POST",
                "url": {
                    "raw": "http://localhost:8080/traffic/int1/resume",
                    "protocol": "http",
                    "host": [
                        "localhost"
                    ],
                    "port": "8080",
                    "path": [
                        "traffic",
                        "int1",
                        "resume"
                    ]
                }
            }
        },
        {
            "name": "Get State",
            "request": {
                "method": "GET",
                "url": {
                    "raw": "http://localhost:8080/traffic/int1/state",
                    "protocol": "http",
                    "host": [
                        "localhost"
                    ],
                    "port": "8080",
                    "path": [
                        "traffic",
                        "int1",
                        "state"
                    ]
                }
            }
        },
        {
            "name": "Get History",
            "request": {
                "method": "GET",
                "url": {
                    "raw": "http://localhost:8080/traffic/int1/history",
                    "protocol": "http",
                    "host": [
                        "localhost"
                    ],
                    "port": "8080",
                    "path": [
                        "traffic",
                        "int1",
                        "history"
                    ]
                }
            }
        }
    ]
}